msgid "Inventory Duplicate Checker"
msgstr "Vérificateur de doublons d'inventaire"

msgid "Duplicate Checker"
msgstr "Vérificateur de doublons"

msgid "Detects duplicates by serial number, UUID, and name"
msgstr "Détecte les doublons par numéro de série, UUID, numéro d'inventaire et nom"

msgid "Rescan"
msgstr "Relancer le scan"

msgid "No duplicates detected"
msgstr "Aucun doublon détecté"

msgid "all inventory items appear to be unique."
msgstr "tous les éléments d'inventaire semblent être uniques."

